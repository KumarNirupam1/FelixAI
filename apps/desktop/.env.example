# Vision answers use gpt-4o-mini. Add your key here, then restart the app.
OPENAI_API_KEY=

# Cognee REST endpoint (self-hosted Docker). Default is fine.
COGNEE_URL=http://localhost:8000

# Optional: absolute path to your cloned cognee repo so Jarvis can auto-start
# the Docker stack if it isn't already running (F9). Leave blank to skip.
COGNEE_REPO_PATH=
