# Screen analysis — OpenRouter vision (free tier)
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional — defaults to nvidia/nemotron-nano-12b-v2-vl:free (best for screen text/charts/UI)
# Alternative for general photo scenes: google/gemma-4-26b-a4b-it:free
# OPENROUTER_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl:free

# Voice input — Deepgram nova-2
# Get a key at https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Cognee REST endpoint (self-hosted Docker) — FelixAI's brain
# Cognee Docker must have LLM_API_KEY set for recall/GRAPH_COMPLETION
COGNEE_URL=http://localhost:8000

# Optional: path to cognee repo for Docker auto-start
COGNEE_REPO_PATH=
